# CloudHub / Anypoint credentials
ANYPOINT_CLIENT_ID=your_client_id
ANYPOINT_CLIENT_SECRET=your_client_secret
ANYPOINT_ORG_ID=your_org_id

# Optional: force subset of environments (comma-separated IDs)
# ANYPOINT_ENV_IDS=env-id-1,env-id-2

# Anypoint URLs
ANYPOINT_BASE_URL=https://anypoint.mulesoft.com
ANYPOINT_AUTH_URL=https://anypoint.mulesoft.com/accounts/api/v2/oauth2/token

# Endpoint templates (override if your tenant exposes different paths)
CLOUDHUB_ENVIRONMENTS_API=/accounts/api/organizations/{org_id}/environments
CLOUDHUB_APIS_API=/cloudhub/api/v2/applications?environmentId={env_id}
CLOUDHUB_SCHEDULES_API=/cloudhub/api/v2/applications/{app_name}/schedules?environmentId={env_id}
CLOUDHUB_RUNS_API=/cloudhub/api/v2/applications/{app_name}/jobs/runs?environmentId={env_id}&limit=200

# Elasticsearch target
ELASTIC_URL=https://your-elastic-host:9200
ELASTIC_API_KEY=base64_api_key
ELASTIC_INDEX_PREFIX=mulesoft-job-runs

# Collector behavior
POLL_INTERVAL_SECONDS=30
HTTP_TIMEOUT_SECONDS=30
STATE_FILE=.cloudhub_collector_state.json
